# Optional. Device and vendor catalogs are read from the sibling growrig-platform
# repo during dev and build, falling back to source/growrig-platform when absent.
# npm run dev watches ../growrig-platform and reloads when definitions change.
GROWRIG_PLATFORM_DIR=../growrig-platform
GROWRIG_DEVICES_DIR=../growrig-platform/devices
GROWRIG_VENDORS_DIR=../growrig-platform/vendors
SITE_URL=https://growrig.dev
BASE_PATH=/
