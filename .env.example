# Optional. Catalog content (devices, vendors, integrations, species, inventory)
# is read from the sibling growrig-catalog repo during dev and build, falling
# back to the platform's catalog/ submodule and then source/growrig-catalog when
# absent. npm run dev watches the catalog and reloads when definitions change.
#
# Override the whole catalog root, or a single directory:
GROWRIG_CATALOG_DIR=../growrig-catalog
# GROWRIG_DEVICES_DIR=../growrig-catalog/devices
# GROWRIG_VENDORS_DIR=../growrig-catalog/vendors
# GROWRIG_INTEGRATIONS_DIR=../growrig-catalog/integrations
# GROWRIG_SPECIES_DIR=../growrig-catalog/species
# GROWRIG_INVENTORY_DIR=../growrig-catalog/inventory
SITE_URL=https://growrig.dev
BASE_PATH=/
