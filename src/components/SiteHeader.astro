---
import Logo from './Logo.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname;

const links = [
  { label: 'Getting Started', href: `${base}/getting-started/`, match: '/getting-started' },
  { label: 'Documentation', href: `${base}/docs/`, match: '/docs' },
];

// The catalog browsers are grouped under a "Catalog" dropdown to keep the
// top-level nav short.
const moreLinks = [
  { label: 'Devices', href: `${base}/devices/`, match: '/devices' },
  { label: 'Products', href: `${base}/products/`, match: '/products' },
  { label: 'Integrations', href: `${base}/integrations/`, match: '/integrations' },
  { label: 'Species', href: `${base}/species/`, match: '/species' },
  { label: 'Vendors', href: `${base}/vendors/`, match: '/vendors' },
];

function isActive(match: string) {
  return path === match || path.startsWith(`${match}/`) || path.startsWith(`${base}${match}`);
}

const moreActive = moreLinks.some((link) => isActive(link.match));
---

<header class="gr-header">
  <div class="gr-container gr-header__inner">
    <a class="gr-header__logo" href={`${base}/`} aria-label="GrowRig home">
      <Logo />
    </a>

    <nav class="gr-nav" id="gr-nav">
      {
        links.map((link) => (
          <a href={link.href} class={isActive(link.match) ? 'is-active' : undefined}>
            {link.label}
          </a>
        ))
      }
      <div class={`gr-nav__group${moreActive ? ' is-active' : ''}`} id="gr-nav-more">
        <button class="gr-nav__trigger" type="button" aria-expanded="false" aria-haspopup="true">
          Catalog
          <svg class="chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </button>
        <div class="gr-nav__menu">
          {
            moreLinks.map((link) => (
              <a href={link.href} class={isActive(link.match) ? 'is-active' : undefined}>
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    <div class="gr-header__spacer"></div>

    <div class="gr-header__actions">
      <button
        class="gr-search-btn"
        id="gr-search-btn"
        type="button"
        aria-label="Search"
        aria-keyshortcuts="Meta+K Control+K"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <span class="gr-search-btn__label">Search</span>
        <kbd class="gr-search-btn__kbd"><kbd>⌘</kbd><kbd>K</kbd></kbd>
      </button>

      <a
        class="gr-icon-btn"
        href="https://github.com/growrig"
        target="_blank"
        rel="noopener"
        aria-label="GrowRig on GitHub"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.79 2.74 1.27 3.4.97.11-.76.41-1.27.74-1.56-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.5 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.4-5.25 5.69.42.36.8 1.08.8 2.18v3.23c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"
          ></path>
        </svg>
      </a>

      <button class="gr-icon-btn gr-theme-toggle" id="gr-theme-toggle" aria-label="Toggle theme">
        <svg class="sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <svg class="moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z"></path>
        </svg>
      </button>

      <button class="gr-icon-btn gr-menu-btn" id="gr-menu-btn" aria-label="Menu" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Search modal. A native <dialog> opened with showModal() renders in the top
     layer with a real ::backdrop — the same approach Starlight's search uses —
     so it can't be occluded by page stacking contexts. It reuses the Pagefind
     index Starlight builds for the docs, so Cmd/Ctrl+K works on these custom
     pages too. Pagefind assets only exist in a production build, so search is
     inert under `astro dev`. -->
<dialog class="gr-search" id="gr-search" aria-label="Search the docs" data-pagefind-base={`${base}/pagefind/`}>
  <div id="gr-search__ui" class="gr-search__ui"></div>
  <div class="gr-search__unavailable" hidden>
    Search runs on the built site. Try it on <a href="https://growrig.dev">growrig.dev</a>.
  </div>
  <p class="gr-search__foot">
    <span><kbd>↵</kbd> to select · <kbd>Esc</kbd> to close</span>
  </p>
</dialog>

<script>
  // Theme toggle — shares the `starlight-theme` localStorage key so the choice
  // persists between these custom pages and the Starlight docs pages.
  const KEY = 'starlight-theme';
  const toggle = document.getElementById('gr-theme-toggle');
  toggle?.addEventListener('click', () => {
    const current =
      document.documentElement.dataset.theme ||
      (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem(KEY, next);
    } catch {}
  });

  // Mobile nav
  const menuBtn = document.getElementById('gr-menu-btn');
  const nav = document.getElementById('gr-nav');
  menuBtn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    menuBtn.setAttribute('aria-expanded', String(!!open));
  });

  // "Other" dropdown — hover/focus opens it via CSS; this adds click + touch
  // toggling and closes it when clicking away or pressing Escape.
  const more = document.getElementById('gr-nav-more');
  const moreTrigger = more?.querySelector('.gr-nav__trigger');
  moreTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = more?.getAttribute('data-open') === 'true';
    more?.setAttribute('data-open', String(!open));
    moreTrigger.setAttribute('aria-expanded', String(!open));
  });
  document.addEventListener('click', () => {
    more?.setAttribute('data-open', 'false');
    moreTrigger?.setAttribute('aria-expanded', 'false');
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      more?.setAttribute('data-open', 'false');
      moreTrigger?.setAttribute('aria-expanded', 'false');
    }
  });

  // Search (Cmd/Ctrl+K) — a native <dialog> reusing Starlight's Pagefind index.
  // Assets are lazily loaded on first open and only exist in a production build.
  const searchBtn = document.getElementById('gr-search-btn');
  const searchModal = document.getElementById('gr-search') as HTMLDialogElement | null;
  const searchUnavailable = searchModal?.querySelector('.gr-search__unavailable') as HTMLElement | null;
  const pagefindBase = searchModal?.getAttribute('data-pagefind-base') ?? '/pagefind/';
  let searchReady: Promise<boolean> | null = null;

  function loadSearch(): Promise<boolean> {
    if (searchReady) return searchReady;
    searchReady = new Promise<boolean>((resolve) => {
      const css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = `${pagefindBase}pagefind-ui.css`;
      document.head.appendChild(css);
      const js = document.createElement('script');
      js.src = `${pagefindBase}pagefind-ui.js`;
      js.onload = () => {
        const PagefindUI = (window as any).PagefindUI;
        if (!PagefindUI) return resolve(false);
        new PagefindUI({
          element: '#gr-search__ui',
          showSubResults: true,
          showImages: false,
          pageSize: 6,
        });
        resolve(true);
      };
      js.onerror = () => resolve(false);
      document.head.appendChild(js);
    });
    return searchReady;
  }

  async function openSearch() {
    if (!searchModal || searchModal.open) return;
    searchModal.showModal();
    const ok = await loadSearch();
    if (searchUnavailable) searchUnavailable.hidden = ok;
    if (ok) {
      searchModal.querySelector<HTMLInputElement>('.pagefind-ui__search-input')?.focus();
    }
  }

  searchBtn?.addEventListener('click', openSearch);
  // Click on the ::backdrop (outside the dialog box) closes it.
  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) searchModal.close();
  });
  // <dialog> handles Escape itself; just intercept Cmd/Ctrl+K to open/toggle.
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      if (searchModal?.open) searchModal.close();
      else openSearch();
    }
  });
</script>
