---
import Logo from './Logo.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---

<footer class="gr-footer">
  <div class="gr-container gr-footer__inner">
    <div class="gr-footer__brand">
      <Logo />
      <p>Open, local-first monitoring and automation for controlled indoor growing.</p>
    </div>

    <div class="gr-footer__cols">
      <div class="gr-footer__col">
        <h4>Learn</h4>
        <a href={`${base}/getting-started/`}>Getting Started</a>
        <a href={`${base}/docs/`}>Documentation</a>
        <a href={`${base}/docs/architecture/`}>Architecture</a>
      </div>
      <div class="gr-footer__col">
        <h4>Catalog</h4>
        <a href={`${base}/devices/`}>Devices</a>
        <a href={`${base}/products/`}>Products</a>
        <a href={`${base}/integrations/`}>Integrations</a>
        <a href={`${base}/species/`}>Species</a>
        <a href={`${base}/vendors/`}>Vendors</a>
      </div>
      <div class="gr-footer__col">
        <h4>Project</h4>
        <a href="https://github.com/growrig" target="_blank" rel="noopener">GitHub</a>
        <a href={`${base}/discord`} target="_blank" rel="noopener">Discord</a>
        <a href={`${base}/docs/roadmap/`}>Roadmap</a>
      </div>
    </div>
  </div>

  <div class="gr-container">
    <div class="gr-footer__legal">
      © {year} GrowRig · Open source · Local-first
    </div>
  </div>
</footer>
