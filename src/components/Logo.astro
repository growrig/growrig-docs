---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
// Unique mask id so multiple logos on one page (header + footer) don't collide.
const maskId = `gr-sprout-${Math.random().toString(36).slice(2, 9)}`;
---

<svg
  class={className}
  viewBox="0 0 188 44"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="GrowRig"
>
  <!-- Sprout knocked out of the square: the page background shows through it,
       so it reads dark on light themes and light on dark themes. -->
  <mask id={maskId} maskUnits="userSpaceOnUse" x="2" y="2" width="40" height="40">
    <rect x="2" y="2" width="40" height="40" rx="10" fill="#fff"></rect>
    <g
      transform="translate(7.5 7.5) scale(1.2)"
      fill="none"
      stroke="#000"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M7 20h10"></path>
      <path d="M10 20c5.5-2.5.8-6.4 3-10"></path>
      <path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"></path>
      <path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"></path>
    </g>
  </mask>
  <rect x="2" y="2" width="40" height="40" rx="10" fill="#34b16a" mask={`url(#${maskId})`}></rect>
  <text
    x="52"
    y="31"
    fill="currentColor"
    font-family="Inter, ui-sans-serif, system-ui, sans-serif"
    font-size="26"
    font-weight="760"
    letter-spacing="-1">GrowRig</text>
</svg>
