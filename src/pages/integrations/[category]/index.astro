---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import LucideIcon from '../../../components/LucideIcon.astro';
import {
  loadIntegrationCategories,
  findIntegrationCategory,
  integrationCount,
  capabilityLabel,
} from '../../../lib/integrations';

export function getStaticPaths() {
  return loadIntegrationCategories().map((cat) => ({ params: { category: cat.slug } }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { category } = Astro.params;
const cat = findIntegrationCategory(category!)!;
---

<SiteLayout
  title={`${cat.name} — Supported integrations — GrowRig`}
  description={`${integrationCount(cat)} ${cat.name.toLowerCase()} integrations GrowRig connects to.`}
>
  <div class="gr-container gr-page-head">
    <nav class="gr-breadcrumb">
      <a href={`${base}/integrations/`}>Supported integrations</a>
      <span>/</span>
      <span>{cat.name}</span>
    </nav>
    <h1>{cat.name}</h1>
    <p>{cat.tagline}</p>
  </div>

  <section class="gr-section" style="padding-top: 1.5rem;">
    <div class="gr-container">
      <div class="gr-toolbar">
        <div class="gr-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="M21 21l-4.3-4.3"></path>
          </svg>
          <input
            type="search"
            id="gr-cat-search"
            placeholder={`Search ${cat.name.toLowerCase()} integrations…`}
            autocomplete="off"
            aria-label={`Search ${cat.name} integrations`}
          />
        </div>
      </div>

      <div class="gr-device-grid" id="gr-cat-grid">
        {cat.integrations.map((i) => (
          <a
            class="gr-device-card"
            href={`${base}/integrations/${i.category}/${i.slug}/`}
            data-search={`${i.name} ${i.description ?? ''} ${i.capabilities.join(' ')}`.toLowerCase()}
          >
            <div class:list={['gr-device-artwork', { 'gr-device-artwork--fallback': !i.icon }]}>
              {i.icon ? (
                <img class="gr-device-artwork__vendor" src={i.icon} alt={`${i.name} icon`} />
              ) : (
                <span class="gr-device-artwork__fallback">
                  <LucideIcon name={cat.icon} size={38} />
                </span>
              )}
            </div>
            <span class="gr-device-card__brand">{cat.name}</span>
            <h3>{i.name}</h3>
            {i.description && <p>{i.description}</p>}
            {i.capabilities.length > 0 && (
              <ul class="gr-device-card__models" aria-label="Capabilities">
                {i.capabilities.map((c) => <li>{capabilityLabel(c)}</li>)}
              </ul>
            )}
            <span class="gr-tags"><span class="gr-tag">{i.runtimeType}</span></span>
          </a>
        ))}
      </div>
      <p class="gr-empty" id="gr-cat-empty" hidden>No integrations match.</p>
    </div>
  </section>
</SiteLayout>

<script>
  const search = document.getElementById('gr-cat-search') as HTMLInputElement | null;
  const empty = document.getElementById('gr-cat-empty');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('#gr-cat-grid .gr-device-card'));

  search?.addEventListener('input', () => {
    const q = (search.value ?? '').trim().toLowerCase();
    let visible = 0;
    for (const card of cards) {
      const show = !q || (card.dataset.search ?? '').includes(q);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    }
    if (empty) empty.hidden = visible !== 0;
  });
</script>
