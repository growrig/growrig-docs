---
import SiteLayout from '../../layouts/SiteLayout.astro';
import LucideIcon from '../../components/LucideIcon.astro';
import CatalogCallout from '../../components/CatalogCallout.astro';
import {
  loadIntegrationCategories,
  allIntegrations,
  integrationCount,
  totalIntegrationCount,
  capabilityLabel,
} from '../../lib/integrations';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const categories = loadIntegrationCategories();
const integrations = allIntegrations();
const total = totalIntegrationCount();

const searchData = integrations.map((i) => ({
  name: i.name,
  category: i.category,
  categoryName: categories.find((c) => c.slug === i.category)?.name ?? i.category,
  categoryIcon: categories.find((c) => c.slug === i.category)?.icon ?? 'plug',
  description: i.description ?? '',
  capabilities: i.capabilities.map(capabilityLabel),
  href: `${base}/integrations/${i.category}/${i.slug}/`,
  icon: i.icon,
}));
---

<SiteLayout
  title="Supported integrations — GrowRig"
  description="External services GrowRig connects to — AI providers, weather data and notification channels."
>
  <div class="gr-container gr-page-head">
    <h1>Supported integrations</h1>
    <p>
      External services GrowRig connects to, grouped by what they do. Each is a reusable bundle you
      configure under <strong>Control panel → Integrations</strong>; secrets are encrypted at rest.
      Pick a category, or search across all {total} integrations.
    </p>
  </div>

  <section class="gr-section" style="padding-top: 1.5rem;">
    <div class="gr-container">
      <div class="gr-toolbar">
        <div class="gr-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="M21 21l-4.3-4.3"></path>
          </svg>
          <input
            type="search"
            id="gr-integration-search"
            placeholder="Search all integrations…"
            autocomplete="off"
            aria-label="Search integrations"
          />
        </div>
      </div>

      <!-- Category grid (default view) -->
      <div class="gr-cat-grid" id="gr-cats">
        {
          categories.map((cat) => (
            <a class="gr-cat-card" href={`${base}/integrations/${cat.slug}/`}>
              <span class="gr-cat-card__icon">
                <LucideIcon name={cat.icon} />
              </span>
              <h3>{cat.name}</h3>
              <p>{cat.tagline}</p>
              <span class="gr-cat-card__count">
                {integrationCount(cat)} integration{integrationCount(cat) === 1 ? '' : 's'}
              </span>
            </a>
          ))
        }
      </div>

      <!-- Search results (hidden until searching) -->
      <div class="gr-device-grid" id="gr-search-results" hidden></div>
      <p class="gr-empty" id="gr-search-empty" hidden>No integrations match your search.</p>

      <CatalogCallout
        noun="integrations"
        docsPath="/docs/adding-an-integration/"
        docsLabel="Add an integration"
      />
    </div>
  </section>
</SiteLayout>

<script define:vars={{ searchData }}>
  const input = document.getElementById('gr-integration-search');
  const cats = document.getElementById('gr-cats');
  const results = document.getElementById('gr-search-results');
  const empty = document.getElementById('gr-search-empty');

  function card(i) {
    const artwork = i.icon
      ? `<img class="gr-device-artwork__vendor" src="${i.icon}" alt="${i.name} icon">`
      : `<span class="gr-device-artwork__fallback">${i.categoryName}</span>`;
    const fallbackClass = i.icon ? '' : ' gr-device-artwork--fallback';
    return `
      <a class="gr-device-card" href="${i.href}">
        <div class="gr-device-artwork${fallbackClass}">${artwork}</div>
        <span class="gr-device-card__brand">${i.categoryName}</span>
        <h3>${i.name}</h3>
        ${i.description ? `<p>${i.description}</p>` : ''}
        ${i.capabilities.length ? `<ul class="gr-device-card__models" aria-label="Capabilities">${i.capabilities.map((c) => `<li>${c}</li>`).join('')}</ul>` : ''}
        <span class="gr-tags"><span class="gr-tag">${i.categoryName}</span></span>
      </a>`;
  }

  input?.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    if (!q) {
      cats.hidden = false;
      results.hidden = true;
      empty.hidden = true;
      results.innerHTML = '';
      return;
    }
    const matches = searchData.filter((i) =>
      [i.name, i.categoryName, i.description, ...i.capabilities].join(' ').toLowerCase().includes(q),
    );
    cats.hidden = true;
    results.innerHTML = matches.map(card).join('');
    results.hidden = matches.length === 0;
    empty.hidden = matches.length !== 0;
  });
</script>
