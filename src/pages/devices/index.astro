---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { loadCategories, allProducts, categoryProductCount, totalProductCount } from '../../lib/devices';
import { loadVendors } from '../../lib/vendors';
import CategoryIcon from '../../components/CategoryIcon.astro';
import CatalogCallout from '../../components/CatalogCallout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const categories = loadCategories();
const products = allProducts();
const total = totalProductCount();
const vendors = new Map(loadVendors().map((vendor) => [vendor.id, vendor]));

// Lightweight data for client-side search.
const searchData = products.map((d) => ({
  title: d.title,
  brand: d.brand,
  category: d.category,
  categoryName: categories.find((c) => c.slug === d.category)?.name ?? d.category,
  connection: d.connectionLabel,
  description: d.description ?? '',
  models: d.models.map((model) => model.model ?? model.id),
  href: `${base}/devices/${d.category}/${d.slug}/`,
  initials: (d.brand || d.title).slice(0, 2).toUpperCase(),
  image: d.image,
  vendorLogo: d.vendor ? vendors.get(d.vendor)?.logo : undefined,
  categoryIcon: categories.find((c) => c.slug === d.category)?.icon ?? '<rect x="4" y="4" width="16" height="16" rx="2"/>',
}));
---

<SiteLayout
  title="Supported devices — GrowRig"
  description="Browse devices that work with GrowRig, organised by category like Home Assistant integrations."
>
  <div class="gr-container gr-page-head">
    <h1>Supported devices</h1>
    <p>
      Devices and equipment that work with GrowRig, grouped by what they do. Pick a category to see
      every profile, or search across all {total} supported products.
    </p>
  </div>

  <section class="gr-section" style="padding-top: 1.5rem;">
    <div class="gr-container">
      <div class="gr-toolbar">
        <div class="gr-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="M21 21l-4.3-4.3"></path>
          </svg>
          <input
            type="search"
            id="gr-device-search"
            placeholder="Search all supported devices…"
            autocomplete="off"
            aria-label="Search supported devices"
          />
        </div>
      </div>

      <!-- Category grid (default view) -->
      <div class="gr-cat-grid" id="gr-cats">
        {
          categories.map((cat) => (
            <a class="gr-cat-card" href={`${base}/devices/${cat.slug}/`}>
              <span class="gr-cat-card__icon">
                <CategoryIcon category={cat.slug} />
              </span>
              <h3>{cat.name}</h3>
              <p>{cat.tagline}</p>
              <span class="gr-cat-card__count">
                {categoryProductCount(cat)} product{categoryProductCount(cat) === 1 ? '' : 's'}
              </span>
            </a>
          ))
        }
      </div>

      <!-- Search results (hidden until searching) -->
      <div class="gr-device-grid" id="gr-search-results" hidden></div>
      <p class="gr-empty" id="gr-search-empty" hidden>No devices match your search.</p>

      <CatalogCallout noun="devices" docsPath="/docs/adding-a-device/" docsLabel="Add a device" />
    </div>
  </section>
</SiteLayout>

<script define:vars={{ searchData }}>
  const input = document.getElementById('gr-device-search');
  const cats = document.getElementById('gr-cats');
  const results = document.getElementById('gr-search-results');
  const empty = document.getElementById('gr-search-empty');

  function card(d) {
    const artwork = d.image
      ? `<img class="gr-device-artwork__product" src="${d.image}" alt="${d.title}">`
      : d.vendorLogo
        ? `<img class="gr-device-artwork__vendor" src="${d.vendorLogo}" alt="${d.brand} logo">`
        : `<span class="gr-device-artwork__fallback"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">${d.categoryIcon}</svg></span>`;
    const fallbackClass = !d.image && !d.vendorLogo ? ' gr-device-artwork--fallback' : '';
    return `
      <a class="gr-device-card" href="${d.href}">
        <div class="gr-device-artwork${fallbackClass}">${artwork}</div>
        <span class="gr-device-card__brand">${d.brand || d.categoryName}</span>
        <h3>${d.title}</h3>
        ${d.description ? `<p>${d.description}</p>` : ''}
        ${d.models.length ? `<ul class="gr-device-card__models" aria-label="Models in this series">${d.models.map((model) => `<li>${model}</li>`).join('')}</ul>` : ''}
        <span class="gr-tags"><span class="gr-tag">${d.categoryName}</span><span class="gr-tag">${d.connection}</span></span>
      </a>`;
  }

  input?.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    if (!q) {
      cats.hidden = false;
      results.hidden = true;
      empty.hidden = true;
      results.innerHTML = '';
      return;
    }
    const matches = searchData.filter((d) =>
      [d.title, d.brand, d.categoryName, d.connection, d.description, ...d.models]
        .join(' ')
        .toLowerCase()
        .includes(q),
    );
    cats.hidden = true;
    results.innerHTML = matches.map(card).join('');
    results.hidden = matches.length === 0;
    empty.hidden = matches.length !== 0;
  });
</script>
