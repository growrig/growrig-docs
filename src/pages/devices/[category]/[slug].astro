---
import { marked } from 'marked';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { loadCategories, findCategory, SPEC_META } from '../../../lib/devices';

export function getStaticPaths() {
  return loadCategories().flatMap((cat) =>
    cat.products.map((d) => ({ params: { category: cat.slug, slug: d.slug } })),
  );
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { category, slug } = Astro.params;
const cat = findCategory(category!)!;
const device = cat.products.find((d) => d.slug === slug)!;

const description = device.description ?? `${device.title} device profile for GrowRig.`;
const definitionUrl = `https://github.com/growrig/growrig-platform/blob/main/devices/${category}/${device.driverSlug}/device.yaml`;

// Render the optional guide, dropping its leading H1 (shown as the page title).
let guideHtml = '';
if (device.guide) {
  const withoutTitle = device.guide.replace(/^#\s+.*\n+/, '');
  guideHtml = await marked.parse(withoutTitle);
}

// Turn the free-form spec map into labelled rows, unknown keys title-cased.
const specRows = Object.entries(device.specs ?? {}).map(([key, value]) => {
  const meta = SPEC_META[key];
  const label = meta?.label ?? key.replace(/([A-Z])/g, ' $1').replace(/^./, (c) => c.toUpperCase());
  return { label, value: meta?.unit ? `${value} ${meta.unit}` : String(value) };
});

// Derive tent air volume when full dimensions are present.
const s = device.specs ?? {};
if (s.widthCm && s.depthCm && s.heightCm) {
  const m3 = (s.widthCm * s.depthCm * s.heightCm) / 1_000_000;
  specRows.push({ label: 'Air volume', value: `${m3.toFixed(2)} m³` });
}

const meta: Array<[string, string]> = [
  ['Category', cat.name],
  ['Brand', device.brand],
  ['Model', device.model],
  ['Connection', device.connectionLabel],
];
if (device.viaDriver) meta.push(['Works via', `${device.driverBrand} ${device.driverModel}`.trim()]);
if (device.version) meta.push(['Definition', `v${device.version}`]);
if (device.author) meta.push(['Maintainer', device.author]);
---

<SiteLayout title={`${device.title} — GrowRig`} description={description}>
  <div class="gr-container gr-page-head">
    <nav class="gr-breadcrumb">
      <a href={`${base}/devices/`}>Supported devices</a>
      <span>/</span>
      <a href={`${base}/devices/${category}/`}>{cat.name}</a>
      <span>/</span>
      <span>{device.model || device.title}</span>
    </nav>
    <h1>{device.title}</h1>
    <p>{description}</p>
    {device.image && <img class="gr-device-hero" src={device.image} alt={device.title} />}
  </div>

  <div class="gr-container gr-detail">
    <div class="gr-prose">
      {
        specRows.length > 0 && (
          <>
            <h2>Specifications</h2>
            <div class="gr-table-wrap">
              <table class="gr-table">
                <tbody>
                  {specRows.map((row) => (
                    <tr>
                      <th style="width: 40%;">{row.label}</th>
                      <td>{row.value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        )
      }

      <h2>Capabilities</h2>
      {
        device.provides.length > 0 ? (
          <div class="gr-table-wrap">
            <table class="gr-table">
              <thead>
                <tr>
                  <th>Capability</th>
                  <th>Kind</th>
                  <th>Entity domain</th>
                  <th>Measurement</th>
                  <th>Suggested role</th>
                </tr>
              </thead>
              <tbody>
                {device.provides.map((c) => (
                  <tr>
                    <td>{c.label}</td>
                    <td><code>{c.kind}</code></td>
                    <td>{c.entityDomain ? <code>{c.entityDomain}</code> : '—'}</td>
                    <td>{c.measurement ?? c.deviceClass ?? '—'}</td>
                    <td>{c.role ?? '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <p>
            No machine-readable capabilities are declared for this profile yet — it documents a
            supported enclosure or reference device.
          </p>
        )
      }

      {
        device.haIntegration && (
          <>
            <h2>Home Assistant</h2>
            <p>
              Connect this device through the <code>{device.haIntegration}</code> integration.
              {device.documentation && (
                <>
                  {' '}
                  <a href={device.documentation} target="_blank" rel="noopener">
                    Integration documentation ↗
                  </a>
                </>
              )}
            </p>
          </>
        )
      }

      {guideHtml && <div class="gr-guide" set:html={guideHtml} />}

      <p style="margin-top:2rem; color: var(--gr-muted); font-size:0.9rem;">
        A catalog entry means GrowRig has a machine-readable profile for this device or device
        class. It does not by itself claim electrical certification, agricultural validation, or
        compatibility with every hardware revision.
      </p>
    </div>

    <aside class="gr-detail__aside">
      <span class="gr-device-card__logo" style="margin-bottom:1rem;">
        {(device.brand || device.title).slice(0, 2).toUpperCase()}
      </span>
      <dl style="margin:0;">
        {
          meta.map(([label, value]) => (
            <div class="gr-meta-row">
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))
        }
      </dl>
      <a class="gr-btn gr-btn--ghost" href={definitionUrl} target="_blank" rel="noopener" style="width:100%; justify-content:center; margin-top:1.25rem;">
        View driver definition ↗
      </a>
    </aside>
  </div>
</SiteLayout>
