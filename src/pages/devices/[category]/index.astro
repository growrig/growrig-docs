---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { loadCategories, findCategory, categoryProductCount } from '../../../lib/devices';
import { loadVendors } from '../../../lib/vendors';
import DeviceArtwork from '../../../components/DeviceArtwork.astro';

export function getStaticPaths() {
  return loadCategories().map((cat) => ({ params: { category: cat.slug } }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { category } = Astro.params;
const cat = findCategory(category!)!;
const vendors = new Map(loadVendors().map((vendor) => [vendor.id, vendor]));

// Unique connection types present in this category, for filter chips.
const connections = [...new Set(cat.products.map((d) => d.connectionLabel))].sort();
const configuredGroups = cat.groups ?? [];
const groupedKeys = new Set(configuredGroups.map((group) => group.key));
const groups = configuredGroups.length > 0
  ? [
      ...configuredGroups.map((group) => ({ ...group, products: cat.products.filter((product) => product.group === group.key) })),
      { key: 'other', label: `Other ${cat.name.toLowerCase()}`, products: cat.products.filter((product) => !product.group || !groupedKeys.has(product.group)) },
    ].filter((group) => group.products.length > 0)
  : [{ key: 'all', label: '', products: cat.products }];
---

<SiteLayout
  title={`${cat.name} — Supported devices — GrowRig`}
  description={`${categoryProductCount(cat)} ${cat.name.toLowerCase()} products that work with GrowRig.`}
>
  <div class="gr-container gr-page-head">
    <nav class="gr-breadcrumb">
      <a href={`${base}/devices/`}>Supported devices</a>
      <span>/</span>
      <span>{cat.name}</span>
    </nav>
    <h1>{cat.name}</h1>
    <p>{cat.tagline}</p>
  </div>

  <section class="gr-section" style="padding-top: 1.5rem;">
    <div class="gr-container">
      <div class="gr-toolbar">
        <div class="gr-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="M21 21l-4.3-4.3"></path>
          </svg>
          <input
            type="search"
            id="gr-cat-search"
            placeholder={`Search ${cat.name.toLowerCase()}…`}
            autocomplete="off"
            aria-label={`Search ${cat.name}`}
          />
        </div>
        {
          connections.length > 1 && (
            <div class="gr-filters" id="gr-cat-filters">
              <button class="gr-chip is-active" data-connection="all">All</button>
              {connections.map((conn) => (
                <button class="gr-chip" data-connection={conn}>
                  {conn}
                </button>
              ))}
            </div>
          )
        }
      </div>

      <div id="gr-cat-groups" class="gr-device-groups">
        {groups.map((group) => (
          <section class="gr-device-group" data-device-group={group.key}>
            {group.label && <h2>{group.label}</h2>}
            <div class="gr-device-grid">
              {group.products.map((d) => (
            <a
              class="gr-device-card"
              href={`${base}/devices/${d.category}/${d.slug}/`}
              data-connection={d.connectionLabel}
              data-search={`${d.title} ${d.brand} ${d.connectionLabel} ${d.description ?? ''} ${d.models.map((model) => model.model ?? model.id).join(' ')}`.toLowerCase()}
            >
              <DeviceArtwork product={d} vendor={d.vendor ? vendors.get(d.vendor) : undefined} />
              <span class="gr-device-card__brand">{d.brand || cat.name}</span>
              <h3>{d.model || d.title}</h3>
              {d.description && <p>{d.description}</p>}
              {d.models.length > 0 && (
                <ul class="gr-device-card__models" aria-label="Models in this series">
                  {d.models.map((model) => <li>{model.model ?? model.id}</li>)}
                </ul>
              )}
              <span class="gr-tags">
                <span class="gr-tag">{d.connectionLabel}</span>
                {d.haIntegration && <span class="gr-tag">{d.haIntegration}</span>}
              </span>
            </a>
              ))}
            </div>
          </section>
        ))}
      </div>
      <p class="gr-empty" id="gr-cat-empty" hidden>No devices match.</p>
    </div>
  </section>
</SiteLayout>

<script>
  const search = document.getElementById('gr-cat-search') as HTMLInputElement | null;
  const filters = document.getElementById('gr-cat-filters');
  const groups = Array.from(document.querySelectorAll<HTMLElement>('.gr-device-group'));
  const empty = document.getElementById('gr-cat-empty');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.gr-device-group .gr-device-card'));
  let activeConnection = 'all';

  function apply() {
    const q = (search?.value ?? '').trim().toLowerCase();
    let visible = 0;
    for (const card of cards) {
      const matchesText = !q || (card.dataset.search ?? '').includes(q);
      const matchesConn = activeConnection === 'all' || card.dataset.connection === activeConnection;
      const show = matchesText && matchesConn;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    }
    for (const group of groups) group.hidden = !Array.from(group.querySelectorAll<HTMLElement>('.gr-device-card')).some((card) => card.style.display !== 'none');
    if (empty) empty.hidden = visible !== 0;
  }

  search?.addEventListener('input', apply);
  filters?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('.gr-chip');
    if (!btn) return;
    activeConnection = btn.dataset.connection ?? 'all';
    filters.querySelectorAll('.gr-chip').forEach((c) => c.classList.remove('is-active'));
    btn.classList.add('is-active');
    apply();
  });
</script>
